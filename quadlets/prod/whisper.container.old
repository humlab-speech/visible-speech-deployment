[Unit]
Description=Whisper Transcription Service
After=network-online.target whisper-net.service

[Container]
ContainerName=whisper
Image=docker.io/library/visp-whisper:latest
Network=whisper-net.network
Volume=@@PROJECT_DIR@@/mounts/whisper/models:/Whisper-WebUI/models:Z
Volume=@@PROJECT_DIR@@/mounts/whisper/outputs:/Whisper-WebUI/outputs:Z
PodmanArgs=--cgroups=disabled

[Service]
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=default.target
