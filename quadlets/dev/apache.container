[Unit]
Description=Apache Web Server with Webclient
After=network-online.target visp-net.service octra-net.service session-manager.service local-idp.service
Wants=session-manager.service local-idp.service

[Container]
ContainerName=apache
Image=localhost/visp-apache:latest
Network=visp-net.network
Network=octra-net.network
PublishPort=@@HTTP_PORT@@:80
EnvironmentFile=@@PROJECT_DIR@@/.env
Environment=LOG_LEVEL=debug
Environment=HTTP_PROTOCOL=http
Secret=visp_api_access_token,type=env,target=HS_API_ACCESS_TOKEN
Secret=visp_mongo_root_password,type=env,target=MONGO_ROOT_PASSWORD
Secret=visp_test_user_login_key,type=env,target=TEST_USER_LOGIN_KEY
# Security hardening
DropCapability=ALL
AddCapability=CHOWN DAC_OVERRIDE SETGID SETUID NET_BIND_SERVICE
NoNewPrivileges=true

# Local test IdP Shibboleth volumes (generated during ./visp.py install in dev mode)
Volume=@@PROJECT_DIR@@/mounts/apache/saml/local-idp/shibboleth2.xml:/etc/shibboleth/shibboleth2.xml:Z
Volume=@@PROJECT_DIR@@/mounts/apache/saml/local-idp/idp-metadata.xml:/etc/shibboleth/local-idp-metadata.xml:Z
Volume=@@PROJECT_DIR@@/mounts/apache/saml/swamid/attribute-map.xml:/etc/shibboleth/attribute-map.xml:Z

# General volumes
Volume=@@PROJECT_DIR@@/mounts/api-logs/logs:/var/log/api:Z
Volume=@@PROJECT_DIR@@/mounts/apache/saml/shib.conf:/etc/apache2/conf-enabled/shib.conf:Z
Volume=@@PROJECT_DIR@@/mounts/apache/apache/remoteip.conf:/etc/apache2/conf-enabled/remoteip.conf:ro,Z
Volume=@@PROJECT_DIR@@/mounts/apache/apache/envvars:/etc/apache2/envvars:Z
Volume=@@PROJECT_DIR@@/mounts/apache/apache/apache2.conf:/etc/apache2/apache2.conf:Z
Volume=@@PROJECT_DIR@@/mounts/apache/apache/vhosts:/etc/apache2/sites-enabled:Z
# DEV MODE: Mount source code for hot-reload development
Volume=@@PROJECT_DIR@@/external/webclient/dist:/var/www/html:Z
# DEV MODE: Mount PHP API source directly so edits are instant (no build needed)
Volume=@@PROJECT_DIR@@/external/webclient/api:/var/www/html/api:Z
Volume=@@PROJECT_DIR@@/mounts/apache/apache/vc.js:/var/www/html/vc.js:ro,Z
Volume=@@PROJECT_DIR@@/mounts/apache/apache/logs/apache2:/var/log/apache2:Z
Volume=@@PROJECT_DIR@@/mounts/apache/apache/logs/shibboleth:/var/log/shibboleth:Z
Volume=@@PROJECT_DIR@@/mounts/apache/saml/shibd.logger:/etc/shibboleth/shibd.logger:Z
# Podman socket removed - PHP API uses HTTP to session-manager, not Docker socket
Volume=@@PROJECT_DIR@@/certs:/etc/certs:Z
Volume=@@PROJECT_DIR@@/certs/letsencrypt:/certs/letsencrypt:Z
Volume=@@PROJECT_DIR@@/mounts/apache/apache/uploads:/tmp/uploads:Z
Volume=@@PROJECT_DIR@@/mounts/apache/apache/php.ini:/etc/php/8.2/apache2/php.ini:Z
Volume=/etc/timezone:/etc/timezone:ro
Volume=/etc/localtime:/etc/localtime:ro
Volume=@@PROJECT_DIR@@/mounts/repositories:/repositories:Z

# Resource limits
PodmanArgs=--memory=512m --cpus=1.0 --pids-limit=300

[Service]
Restart=always
TimeoutStartSec=300

[Install]
WantedBy=default.target
