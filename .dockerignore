# Exclude large/unnecessary directories to reduce build context
.git
.github
mounts
certs/letsencrypt
private
node_modules
__pycache__
*.log

# Exclude other service directories (not needed for artic build)
webclient
webapi
session-manager
wsrng-server
emu-webapp-server
container-agent

# Keep artic and docker/artic (needed for build)
# These are implicitly included by not being listed above
